<!-- Dashboard Page -->
<section class="dashboard-v4">
  <!-- KPI Cards -->
  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(255, 77, 58, 0.12); color: #FF4D3A;">
        <i data-lucide="box"></i>
      </div>
      <div class="kpi-label">Total Produk</div>
      <div class="kpi-value" id="kpiProduk">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(34, 197, 94, 0.12); color: #22C55E;">
        <i data-lucide="store"></i>
      </div>
      <div class="kpi-label">Total Outlet</div>
      <div class="kpi-value" id="kpiOutlet">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(245, 158, 11, 0.12); color: #F59E0B;">
        <i data-lucide="warehouse"></i>
      </div>
      <div class="kpi-label">Stok Gudang</div>
      <div class="kpi-value" id="kpiStokGudang">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(59, 130, 246, 0.12); color: #3B82F6;">
        <i data-lucide="truck"></i>
      </div>
      <div class="kpi-label">Stok Outlet</div>
      <div class="kpi-value" id="kpiStokOutlet">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(168, 85, 247, 0.12); color: #A855F7;">
        <i data-lucide="send"></i>
      </div>
      <div class="kpi-label">Distribusi Hari Ini</div>
      <div class="kpi-value" id="kpiDistribusi">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(236, 72, 153, 0.12); color: #EC4899;">
        <i data-lucide="shopping-cart"></i>
      </div>
      <div class="kpi-label">Penjualan Hari Ini</div>
      <div class="kpi-value" id="kpiPenjualan">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(245, 158, 11, 0.12); color: #F59E0B;">
        <i data-lucide="clipboard-list"></i>
      </div>
      <div class="kpi-label">SO Pending</div>
      <div class="kpi-value" id="kpiSOPending">-</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="background: rgba(239, 68, 68, 0.12); color: #EF4444;">
        <i data-lucide="alert-triangle"></i>
      </div>
      <div class="kpi-label">Stok Kritis</div>
      <div class="kpi-value" id="kpiStokKritis">-</div>
    </div>
  </div>

  <!-- Main Grid: Chart Area + Right Panel -->
  <div class="dashboard-main-grid">
    <div class="dashboard-chart-area">
      <!-- Distribution Chart -->
      <div class="chart-card">
        <div class="chart-card__header">
          <h3 class="chart-card__title">Distribusi 7 Hari Terakhir</h3>
          <span class="chart-card__timestamp" id="chartTimestamp"></span>
        </div>
        <div class="chart-container">
          <canvas id="distributionChart"></canvas>
        </div>
      </div>

      <!-- Recent Distribution -->
      <div class="bottom-card">
        <h3 class="bottom-card__title">
          <i data-lucide="send"></i>
          Distribusi Terbaru
        </h3>
        <div class="activity-list" id="recentDistribution">
          <div class="activity-empty">Belum ada distribusi hari ini</div>
        </div>
      </div>
    </div>

    <!-- Right Panel: Critical Stock -->
    <div class="right-panel">
      <div class="stok-kritis-card">
        <h3 class="stok-kritis-card__title">
          <i data-lucide="alert-triangle"></i>
          Stok Kritis
        </h3>
        <div class="stok-kritis-list" id="stokKritisList">
          <div class="stok-kritis-empty">Tidak ada stok kritis</div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="bottom-card">
        <h3 class="bottom-card__title">
          <i data-lucide="activity"></i>
          Aktivitas Terbaru
        </h3>
        <div class="activity-list" id="recentActivity">
          <div class="activity-empty">Tidak ada aktivitas terbaru</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Dashboard initialization
  async function initDashboard() {
    await loadKPIData();
    await loadDistributionChart();
    await loadRecentDistribution();
    await loadStokKritis();
    await loadRecentActivity();
    
    // Hide app loader
    const loader = document.getElementById('appLoader');
    if (loader) {
      loader.classList.add('hidden');
      setTimeout(() => loader.remove(), 500);
    }
  }

  // Load KPI Data
  async function loadKPIData() {
    try {
      const response = await fetch('/api/v1/dashboard/kpi');
      if (!response.ok) throw new Error('Failed to load KPI');
      const data = await response.json();
      
      document.getElementById('kpiProduk').textContent = data.total_produk || 0;
      document.getElementById('kpiOutlet').textContent = data.total_outlet || 0;
      document.getElementById('kpiStokGudang').textContent = data.stok_gudang || 0;
      document.getElementById('kpiStokOutlet').textContent = data.stok_outlet || 0;
      document.getElementById('kpiDistribusi').textContent = data.distribusi_hari_ini || 0;
      document.getElementById('kpiPenjualan').textContent = data.penjualan_hari_ini || 0;
      document.getElementById('kpiSOPending').textContent = data.so_pending || 0;
      document.getElementById('kpiStokKritis').textContent = data.stok_kritis || 0;
    } catch (error) {
      console.error('Error loading KPI:', error);
      // Show placeholder data for demo
      document.getElementById('kpiProduk').textContent = '0';
      document.getElementById('kpiOutlet').textContent = '0';
      document.getElementById('kpiStokGudang').textContent = '0';
      document.getElementById('kpiStokOutlet').textContent = '0';
      document.getElementById('kpiDistribusi').textContent = '0';
      document.getElementById('kpiPenjualan').textContent = '0';
      document.getElementById('kpiSOPending').textContent = '0';
      document.getElementById('kpiStokKritis').textContent = '0';
    }
  }

  // Load Distribution Chart
  async function loadDistributionChart() {
    const ctx = document.getElementById('distributionChart');
    if (!ctx) return;
    
    try {
      const response = await fetch('/api/v1/dashboard/distribution-chart');
      if (!response.ok) throw new Error('Failed to load chart');
      const data = await response.json();
      
      // Update timestamp
      document.getElementById('chartTimestamp').textContent = new Date().toLocaleString('id-ID');
      
      // Chart rendering would go here with Chart.js
      // For now, just show empty state
    } catch (error) {
      console.error('Error loading chart:', error);
    }
  }

  // Load Recent Distribution
  async function loadRecentDistribution() {
    const container = document.getElementById('recentDistribution');
    if (!container) return;
    
    try {
      const response = await fetch('/api/v1/dashboard/recent-distribution');
      if (!response.ok) throw new Error('Failed to load distribution');
      const data = await response.json();
      
      if (data.length === 0) {
        container.innerHTML = '<div class="activity-empty">Belum ada distribusi hari ini</div>';
        return;
      }
      
      container.innerHTML = data.slice(0, 5).map(item => `
        <div class="activity-item">
          <div class="activity-item__icon activity-item__icon--primary">
            <i data-lucide="send"></i>
          </div>
          <div class="activity-item__content">
            <div class="activity-item__text">${item.keterangan || 'Distribusi'}</div>
            <div class="activity-item__meta">${item.waktu || ''}</div>
          </div>
        </div>
      `).join('');
      
      if (window.lucide) lucide.createIcons({ nodes: [container] });
    } catch (error) {
      console.error('Error loading distribution:', error);
    }
  }

  // Load Critical Stock
  async function loadStokKritis() {
    const container = document.getElementById('stokKritisList');
    if (!container) return;
    
    try {
      const response = await fetch('/api/v1/dashboard/stok-kritis');
      if (!response.ok) throw new Error('Failed to load stok kritis');
      const data = await response.json();
      
      if (data.length === 0) {
        container.innerHTML = '<div class="stok-kritis-empty">Tidak ada stok kritis</div>';
        return;
      }
      
      container.innerHTML = data.slice(0, 5).map(item => `
        <div class="stok-kritis-item">
          <div class="stok-kritis-item__info">
            <div class="stok-kritis-item__nama">${item.nama_produk}</div>
            <div class="stok-kritis-item__stok">
              <span>Stok: ${item.stok}</span>
              <span class="stok-kritis-item__min">Min: ${item.stok_minimum}</span>
            </div>
          </div>
          <span class="stok-kritis-item__status stok-kritis-item__status--critical">Kritis</span>
        </div>
      `).join('');
    } catch (error) {
      console.error('Error loading stok kritis:', error);
    }
  }

  // Load Recent Activity
  async function loadRecentActivity() {
    const container = document.getElementById('recentActivity');
    if (!container) return;
    
    try {
      const response = await fetch('/api/v1/dashboard/recent-activity');
      if (!response.ok) throw new Error('Failed to load activity');
      const data = await response.json();
      
      if (data.length === 0) {
        container.innerHTML = '<div class="activity-empty">Tidak ada aktivitas terbaru</div>';
        return;
      }
      
      container.innerHTML = data.slice(0, 5).map(item => `
        <div class="activity-item">
          <div class="activity-item__icon activity-item__icon--${item.tipe || 'primary'}">
            <i data-lucide="${item.icon || 'activity'}"></i>
          </div>
          <div class="activity-item__content">
            <div class="activity-item__text">${item.deskripsi}</div>
            <div class="activity-item__meta">${item.waktu}</div>
          </div>
        </div>
      `).join('');
      
      if (window.lucide) lucide.createIcons({ nodes: [container] });
    } catch (error) {
      console.error('Error loading activity:', error);
    }
  }

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDashboard);
  } else {
    initDashboard();
  }
</script>