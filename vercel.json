{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/app.html",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/sync-shipments",
      "schedule": "*/15 * * * *"
    }
  ],
  "env": {
    "DATABASE_URL": "postgresql://neondb_owner:npg_NHY3t7qdiVAL@ep-super-glade-a1izmh9v-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
  }
}
